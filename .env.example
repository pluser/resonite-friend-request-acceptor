# Resonite credentials
RESONITE_USERNAME=your_resonite_username
RESONITE_PASSWORD=your_resonite_password
# Optional: TOTP code if 2FA is enabled (leave empty if not)
RESONITE_TOTP=

# Discord bot token
DISCORD_TOKEN=your_discord_bot_token
# Discord channel ID where friend request notifications will be sent
DISCORD_CHANNEL_ID=your_channel_id

# Polling interval in seconds for checking new friend requests (default: 60)
POLL_INTERVAL_SECONDS=60

# Health check server port (default: 8080)
HEALTH_PORT=8080
