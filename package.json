{
  "name": "resonite-friend-request-acceptor",
  "version": "1.0.0",
  "description": "Forward Resonite friend requests to Discord and accept/ignore them via Discord buttons",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
